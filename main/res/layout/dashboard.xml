<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/window_background"
    tools:context=".DashboardActivity">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:paddingTop="64dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dashboard"
            android:textColor="@color/text_primary"
            android:textSize="36sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.03" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manage your availability"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="120dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:orientation="vertical">

            <!-- Card: BUSY -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBusy"
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="84dp"
                android:layout_marginBottom="16dp"
                android:layout_marginHorizontal="4dp"
                android:clickable="true"
                android:focusable="true"
                android:checkable="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:paddingHorizontal="20dp">
                    <ImageView android:id="@+id/icBusy" android:layout_width="28dp" android:layout_height="28dp" android:layout_centerVertical="true" android:src="@drawable/ic_busy" app:tint="@color/busy_accent" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_toEndOf="@id/icBusy" android:layout_marginStart="16dp" android:text="Busy" android:textColor="@color/text_primary" android:textSize="18sp" android:fontFamily="sans-serif-bold" />
                    <ImageButton android:id="@+id/btnTimerBusy" android:layout_width="44dp" android:layout_height="44dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_timer" app:tint="@color/text_secondary" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: DRIVING -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDriving"
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="84dp"
                android:layout_marginBottom="16dp"
                android:layout_marginHorizontal="4dp"
                android:clickable="true"
                android:focusable="true"
                android:checkable="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:paddingHorizontal="20dp">
                    <ImageView android:id="@+id/icDriving" android:layout_width="28dp" android:layout_height="28dp" android:layout_centerVertical="true" android:src="@drawable/ic_driving" app:tint="@color/driving_accent" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_toEndOf="@id/icDriving" android:layout_marginStart="16dp" android:text="Driving" android:textColor="@color/text_primary" android:textSize="18sp" android:fontFamily="sans-serif-bold" />
                    <ImageButton android:id="@+id/btnTimerDriving" android:layout_width="44dp" android:layout_height="44dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_timer" app:tint="@color/text_secondary" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: SLEEPING -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSleeping"
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="84dp"
                android:layout_marginBottom="16dp"
                android:layout_marginHorizontal="4dp"
                android:clickable="true"
                android:focusable="true"
                android:checkable="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:paddingHorizontal="20dp">
                    <ImageView android:id="@+id/icSleeping" android:layout_width="28dp" android:layout_height="28dp" android:layout_centerVertical="true" android:src="@drawable/ic_sleeping" app:tint="@color/sleeping_accent" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_toEndOf="@id/icSleeping" android:layout_marginStart="16dp" android:text="Sleeping" android:textColor="@color/text_primary" android:textSize="18sp" android:fontFamily="sans-serif-bold" />
                    <ImageButton android:id="@+id/btnTimerSleeping" android:layout_width="44dp" android:layout_height="44dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_timer" app:tint="@color/text_secondary" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: IN CLASS -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardClass"
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="84dp"
                android:layout_marginBottom="16dp"
                android:layout_marginHorizontal="4dp"
                android:clickable="true"
                android:focusable="true"
                android:checkable="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:paddingHorizontal="20dp">
                    <ImageView android:id="@+id/icClass" android:layout_width="28dp" android:layout_height="28dp" android:layout_centerVertical="true" android:src="@drawable/ic_class" app:tint="@color/class_mode_accent" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_toEndOf="@id/icClass" android:layout_marginStart="16dp" android:text="In Class" android:textColor="@color/text_primary" android:textSize="18sp" android:fontFamily="sans-serif-bold" />
                    <ImageButton android:id="@+id/btnTimerClass" android:layout_width="44dp" android:layout_height="44dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_timer" app:tint="@color/text_secondary" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Custom Modes Container -->
            <LinearLayout android:id="@+id/customModesContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />

            <!-- Card: TURN OFF -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOff"
                style="@style/Widget.Material3.CardView.Elevated"
                android:layout_width="match_parent"
                android:layout_height="84dp"
                android:layout_marginBottom="32dp"
                android:layout_marginHorizontal="4dp"
                android:clickable="true"
                android:focusable="true"
                android:checkable="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent" android:paddingHorizontal="20dp">
                    <ImageView android:id="@+id/icOff" android:layout_width="28dp" android:layout_height="28dp" android:layout_centerVertical="true" android:src="@drawable/ic_off" app:tint="@color/turnoff_accent" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_toEndOf="@id/icOff" android:layout_marginStart="16dp" android:text="Turn Off" android:textColor="@color/text_primary" android:textSize="18sp" android:fontFamily="sans-serif-bold" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Footer Branding -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_horizontal" android:text="Developed by Devanshu Kumar" android:textColor="@color/text_secondary" android:textSize="13sp" android:alpha="0.6" android:fontFamily="sans-serif-medium" />
            <TextView android:id="@+id/githubLink" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_horizontal" android:layout_marginTop="4dp" android:layout_marginBottom="60dp" android:text="github.com/devanshuk3" android:textColor="@color/custom_mode_accent" android:textSize="13sp" android:fontFamily="sans-serif-bold" />

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddCustom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="28dp"
        android:contentDescription="Add custom mode"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/fab_background"
        app:tint="@color/white"
        app:fabSize="normal"
        app:elevation="8dp"
        app:maxImageSize="32dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="UTF-8"?>
<dashboard>
    <metadata>
        <title>DASHBOARD</title>
        <version>1.0.0</version>
        <description>Status management dashboard with interactive controls</description>
    </metadata>

    <layout>
        <container type="main" class="bg-white w-full min-h-screen flex flex-col items-center">
            <padding>
                <mobile>px-4 py-8</mobile>
                <tablet>px-8 py-8</tablet>
                <desktop>px-38 py-68</desktop>
            </padding>
            <gap>
                <mobile>gap-8</mobile>
                <desktop>gap-68</desktop>
            </gap>
        </container>
    </layout>

    <header>
        <card maxWidth="1020px">
            <content height="158px" alignment="center">
                <title font="Gurajada" size="87px" color="black">DASHBOARD</title>
            </content>
        </card>
    </header>

    <statusOptions>
        <option id="1">
            <label>BUSY</label>
            <backgroundColor>bg-purple-500</backgroundColor>
            <hoverColor>hover:bg-purple-600</hoverColor>
            <icon>https://c.animaapp.com/mlgf2kyugq3Qw0/img/rectangle-6.svg</icon>
            <height>150px</height>
        </option>

        <option id="2">
            <label>DRIVING</label>
            <backgroundColor>bg-cyan-400</backgroundColor>
            <hoverColor>hover:bg-cyan-500</hoverColor>
            <icon>https://c.animaapp.com/mlgf2kyugq3Qw0/img/rectangle-7.svg</icon>
            <height>150px</height>
        </option>

        <option id="3">
            <label>SLEEPING</label>
            <backgroundColor>bg-pink-500</backgroundColor>
            <hoverColor>hover:bg-pink-600</hoverColor>
            <icon>https://c.animaapp.com/mlgf2kyugq3Qw0/img/rectangle-8.svg</icon>
            <height>150px</height>
        </option>

        <option id="4">
            <label>TURN OFF</label>
            <backgroundColor>bg-orange-400</backgroundColor>
            <hoverColor>hover:bg-orange-500</hoverColor>
            <icon>https://c.animaapp.com/mlgf2kyugq3Qw0/img/rectangle-9.svg</icon>
            <height>150px</height>
        </option>
    </statusOptions>

    <interactions>
        <animation type="fade-in" duration="0.8s" easing="cubic-bezier(0.16, 1, 0.3, 1)">
            <stagger delay="200ms" />
        </animation>

        <hover>
            <effect type="shadow" value="shadow-2xl" />
            <effect type="scale" value="scale-110" target="icon" />
        </hover>

        <active>
            <effect type="ring" value="ring-4 ring-white ring-offset-4" />
        </active>

        <notification>
            <position>bottom-center</position>
            <style>bg-black text-white px-6 py-3 rounded-full shadow-lg</style>
            <animation>animate-fade-in</animation>
        </notification>
    </interactions>

    <responsive>
        <breakpoint name="mobile" maxWidth="640px">
            <header fontSize="48px" height="100px" />
            <statusCard fontSize="36px" iconSize="64px" height="100px" padding="px-4" />
        </breakpoint>

        <breakpoint name="tablet" minWidth="641px" maxWidth="768px">
            <header fontSize="64px" height="130px" />
            <statusCard fontSize="56px" iconSize="80px" height="120px" padding="px-6" />
        </breakpoint>

        <breakpoint name="desktop" minWidth="769px">
            <header fontSize="87px" height="158px" />
            <statusCard fontSize="87px" iconSize="112px" height="150px" padding="px-8" />
        </breakpoint>
    </responsive>

    <accessibility>
        <keyboard enabled="true">
            <keys>Enter, Space</keys>
        </keyboard>
        <aria>
            <role>button</role>
            <pressed>dynamic</pressed>
            <label>Set status to {label}</label>
        </aria>
        <tabIndex>0</tabIndex>
    </accessibility>


</dashboard>

<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <project>
        <name>Anima Dashboard Project</name>
        <version>1.0.0</version>
        <type>React Application</type>
        <description>A React project automatically generated by Anima using the Shadcn UI library</description>
    </project>

    <dependencies>
        <runtime>
            <package name="clsx" version="2.1.1" />
            <package name="lucide-react" version="^0.453.0" />
            <package name="react" version="^18.2.0" />
            <package name="react-dom" version="^18.2.0" />
            <package name="react-router-dom" version="^6.8.1" />
            <package name="tailwind-merge" version="2.5.4" />
            <package name="tailwindcss-animate" version="1.0.7" />
        </runtime>

        <development>
            <package name="@animaapp/vite-plugin-screen-graph" version="^0.1.5" />
            <package name="@types/react" version="18.2.0" />
            <package name="@types/react-dom" version="18.2.0" />
            <package name="@vitejs/plugin-react" version="4.3.4" />
            <package name="esbuild" version="0.24.0" />
            <package name="globals" version="15.12.0" />
            <package name="tailwindcss" version="3.4.16" />
            <package name="vite" version="6.0.4" />
        </development>
    </dependencies>

    <scripts>
        <script name="dev" command="vite" />
        <script name="build" command="vite build" />
    </scripts>

    <fonts>
        <font name="Gurajada" weight="400" source="https://fonts.googleapis.com/css?family=Gurajada:400" />
    </fonts>

    <theme>
        <colors>
            <color name="background" value="0 0% 100%" />
            <color name="foreground" value="222.2 47.4% 11.2%" />
            <color name="card" value="transparent" />
            <color name="card-foreground" value="222.2 47.4% 11.2%" />
            <color name="primary" value="222.2 47.4% 11.2%" />
            <color name="primary-foreground" value="210 40% 98%" />
            <color name="secondary" value="210 40% 96.1%" />
            <color name="secondary-foreground" value="222.2 47.4% 11.2%" />
            <color name="muted" value="210 40% 96.1%" />
            <color name="muted-foreground" value="215.4 16.3% 46.9%" />
            <color name="accent" value="210 40% 96.1%" />
            <color name="accent-foreground" value="222.2 47.4% 11.2%" />
            <color name="destructive" value="0 100% 50%" />
            <color name="destructive-foreground" value="210 40% 98%" />
            <color name="border" value="214.3 31.8% 91.4%" />
            <color name="input" value="214.3 31.8% 91.4%" />
            <color name="ring" value="215 20.2% 65.1%" />
        </colors>

        <borderRadius>
            <size name="lg" value="var(--radius)" />
            <size name="md" value="calc(var(--radius) - 2px)" />
            <size name="sm" value="calc(var(--radius) - 4px)" />
        </borderRadius>

        <container>
            <center>true</center>
            <padding>2rem</padding>
            <maxWidth>1400px</maxWidth>
        </container>
    </theme>

    <animations>
        <keyframe name="fade-in">
            <from opacity="0" transform="translateY(-10px)" />
            <to opacity="1" transform="none" />
        </keyframe>

        <keyframe name="fade-up">
            <from opacity="0" transform="translateY(20px)" />
            <to opacity="1" transform="none" />
        </keyframe>

        <keyframe name="spin">
            <to transform="rotate(1turn)" />
        </keyframe>

        <keyframe name="shimmer">
            <at percent="0" position="calc(-100% - var(--shimmer-width)) 0" />
            <at percent="30" position="calc(100% + var(--shimmer-width)) 0" />
            <at percent="60" position="calc(100% + var(--shimmer-width)) 0" />
            <at percent="90" position="calc(-100% - var(--shimmer-width)) 0" />
            <at percent="100" position="calc(-100% - var(--shimmer-width)) 0" />
        </keyframe>

        <keyframe name="marquee">
            <from transform="translate(0)" />
            <to transform="translateX(calc(-100% - var(--gap)))" />
        </keyframe>

        <keyframe name="marquee-vertical">
            <from transform="translateY(0)" />
            <to transform="translateY(calc(-100% - var(--gap)))" />
        </keyframe>

        <keyframe name="accordion-down">
            <from height="0" />
            <to height="var(--radix-accordion-content-height)" />
        </keyframe>

        <keyframe name="accordion-up">
            <from height="var(--radix-accordion-content-height)" />
            <to height="0" />
        </keyframe>
    </animations>

    <build>
        <source>./index.html</source>
        <publicDir>./static</publicDir>
        <base>./</base>
        <target>ES2020</target>
        <module>ESNext</module>
        <jsx>react-jsx</jsx>
    </build>
</configuration>
